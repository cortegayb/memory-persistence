# IMPORTANTE: Los templates aquí son EJEMPLOS.
# Tu memoria PERSONAL (diarios, proyectos, datos) debe estar en .gitignore
# o NO subirse a git.

# ── Contenido personal del cerebro (NUNCA subir) ─────────────
# Base de datos con tus recuerdos + logs
*.db
*.db-wal
*.db-shm
memory.db
consolidation.log

# Recuerdos concretos (solo se versionan las .templates/)
memory/feedback_*.md
memory/project_*.md
memory/diario_*.md
memory/user_*.md
memory/reference_*.md
memory/MEMORY.md

# Credenciales y secretos
.env
.env.local
.env.*.local
*.key
*.pem
credentials/
secrets/
private/

# Sistema
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
.project

# Logs
*.log
logs/

# Node (si aplica)
node_modules/
package-lock.json
yarn.lock

# Python (si aplica)
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Temporal
.tmp/
temp/
*.tmp

# Sync/Backup
backups/
sync/
*.tar.gz
memory_backup_*

# IDE
.DS_Store
.AppleDouble
.LSOverride
*.sublime-project
*.sublime-workspace
